# UnbiasedAI — environment variables
# Copy this file to .env and fill in your values

# Gemini API key (get one free at https://aistudio.google.com)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Backend URL — change to your ngrok/Cloud Run URL when deploying
# Default: local FastAPI server
VITE_API_URL=http://localhost:8001

# Set to 'false' to disable mock data fallback (force live backend)
VITE_USE_MOCK=false
