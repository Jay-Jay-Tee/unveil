# ── Backend API (FastAPI, localhost:8001) ─────────────────────────────
VITE_API_URL=http://localhost:8001

# Set to 'false' to disable mock fallback when backend is offline.
# Default is on, so demos work without a server.
VITE_USE_MOCK=true

# ── Gemini (used as browser-side fallback when backend is down) ───────
# Get a free key at https://aistudio.google.com
VITE_GEMINI_API_KEY=

# ── Firebase (OPTIONAL — app falls back to localStorage if not set) ───
# Get these from: https://console.firebase.google.com
# Project settings → General → Your apps → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
