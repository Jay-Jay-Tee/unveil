# -- Backend API (FastAPI, localhost:8001) -----------------------------
VITE_API_URL=http://localhost:8001

# Set to 'false' to allow unauthenticated backend analysis calls.
# Keep this as true in production.
VITE_REQUIRE_AUTH_FOR_ANALYSIS=true

# Set to 'false' to disable mock fallback when backend is offline.
# Default is on, so demos work without a server.
VITE_USE_MOCK=true

# -- Gemini (used as browser-side fallback when backend is down) -------
# Get a free key at https://aistudio.google.com
VITE_GEMINI_API_KEY=

# -- Firebase (OPTIONAL - app falls back to localStorage if not set) ---
# Get these from: https://console.firebase.google.com
# Project settings → General → Your apps → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# -- Backend auth enforcement (FastAPI) ---------------------------------
# Keep true in production to require Firebase ID tokens.
AUTH_REQUIRED=true

# Set false in production to disallow arbitrary localhost origins.
ALLOW_LOCALHOST_CORS=true

# Optional: absolute path to a Firebase service account JSON file.
# If omitted, Firebase Admin uses GOOGLE_APPLICATION_CREDENTIALS/default credentials.
FIREBASE_SERVICE_ACCOUNT_PATH=
